{
  "name": "xpert-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "set PRISMA_CLIENT_ENGINE_TYPE=binary&& node server.js",
    "start:prod": "set PRISMA_CLIENT_ENGINE_TYPE=binary&& npx prisma migrate deploy && npx prisma generate && node server.js",
    "dev": "set PRISMA_CLIENT_ENGINE_TYPE=binary&& node server.js",
    "build": "set PRISMA_CLIENT_ENGINE_TYPE=binary&& prisma generate",
    "db:check": "node scripts/check-db-connection.js",
    "db:users": "node scripts/list-users.js",
    "db:pull": "prisma db pull --schema prisma/schema.prisma",
    "db:generate": "set PRISMA_CLIENT_ENGINE_TYPE=binary&& prisma generate --schema prisma/schema.prisma",
    "db:sync": "node scripts/db-sync-safe.js",
    "db:migrate": "set PRISMA_CLIENT_ENGINE_TYPE=binary&& npx prisma migrate deploy && npx prisma generate",
    "prisma:generate": "set PRISMA_CLIENT_ENGINE_TYPE=binary&& prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "seed:login-accounts": "node scripts/seed-login-accounts.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@supabase/supabase-js": "^2.95.3",
    "@types/pg": "^8.16.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "mysql2": "^3.16.3",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.15",
    "@types/node": "^25.2.2",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
